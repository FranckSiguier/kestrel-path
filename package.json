{
  "name": "kestrel-path",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "db:push": "turbo -F @kestrel-path/db db:push",
    "db:studio": "turbo -F @kestrel-path/db db:studio",
    "db:generate": "turbo -F @kestrel-path/db db:generate",
    "db:migrate": "turbo -F @kestrel-path/db db:migrate",
    "db:local": "turbo -F @kestrel-path/db db:local"
  },
  "dependencies": {
    "@kestrel-path/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kestrel-path/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.10.0"
}
