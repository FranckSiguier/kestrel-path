{
  "name": "kestrel-path",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^6",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@libsql/client": "0.15.15",
      "libsql": "0.5.22",
      "better-auth": "1.5.5",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "storage:up": "docker compose up -d minio minio-init",
    "storage:down": "docker compose down",
    "db:push": "turbo -F @kestrel-path/db db:push",
    "db:studio": "turbo -F @kestrel-path/db db:studio",
    "db:generate": "turbo -F @kestrel-path/db db:generate",
    "db:migrate": "turbo -F @kestrel-path/db db:migrate",
    "db:local": "turbo -F @kestrel-path/db db:local"
  },
  "dependencies": {
    "@kestrel-path/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@kestrel-path/config": "workspace:*",
    "@types/node": "^22.13.14",
    "bun-types": "^1.3.13",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.12"
}
